---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { createHash } from "node:crypto";
import LockGate from "../../components/LockGate.astro";

const BASE = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + "/";

export async function getStaticPaths() {
  const items = await getCollection("research", ({ data }) => !data.draft);
  return items.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await item.render();
const lockHash = item.data.lockPasscode
  ? createHash("sha256").update(item.data.lockPasscode).digest("hex")
  : "";
const storageKey = `research/${item.slug}`;
---
<BaseLayout title={`${item.data.title} | 研究 | ねこねこ通信`}>
  <article class="plainArticle">
    <h1 class="h1">{item.data.title}</h1>
    {item.data.summary ? <p class="summaryLead">{item.data.summary}</p> : null}
    <LockGate
      locked={item.data.locked}
      lockHash={lockHash}
      storageKey={storageKey}
    >
      <div class="prose">
        <Content />
      </div>
    </LockGate>
  </article>
</BaseLayout>

<style>
  .plainArticle {
    padding: 0;
    margin: 0;
    padding-top: 15px;
    max-width: 760px;
    margin-inline: auto;
  }

  .plainArticle .h1 {
    margin: 0;
    font-size: clamp(1.38rem, 2.9vw, 1.86rem);
    line-height: 1.28;
    color: var(--accent);
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Hiragino Sans",
      "Yu Gothic",
      "Noto Sans JP",
      sans-serif;
    font-weight: 400;
  }

  .summaryLead {
    margin: 0 0 14px;
    color: var(--muted);
    opacity: 0.86;
    font-size: 0.92rem;
    line-height: 1.6;
  }

  .prose :global(p) {
    margin: 0 0 1.05em;
    font-size: 1rem;
  }

  .prose :global(a) {
    text-decoration: none;
  }

  .prose :global(a:hover) {
    text-decoration: underline;
  }

  .prose :global(h2) {
    margin: 1.8em 0 0.7em;
    font-size: 1.18rem;
    font-weight: 500;
    color: var(--accent);
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Hiragino Sans",
      "Yu Gothic",
      "Noto Sans JP",
      sans-serif;
  }

  .prose :global(h3) {
    margin: 1.5em 0 0.6em;
    font-size: 1.02rem;
    font-weight: 400;
    color: var(--accent);
    opacity: 1;
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Hiragino Sans",
      "Yu Gothic",
      "Noto Sans JP",
      sans-serif;
  }
</style>
